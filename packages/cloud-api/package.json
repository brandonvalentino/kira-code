{
  "name": "@kira/cloud-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@aws-sdk/s3-request-presigner": "^3.1009.0",
    "@hono/node-server": "^1.14.0",
    "@hono/zod-openapi": "^0.19.10",
    "@kira/shared": "workspace:*",
    "@scalar/hono-api-reference": "^0.10.3",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.12.7",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.2",
    "postgres": "^3.4.8",
    "uuid": "^10.0.0",
    "ws": "^8.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.13.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.0.0",
    "drizzle-kit": "^0.30.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.2",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
