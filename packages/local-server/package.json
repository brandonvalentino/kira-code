    "@scalar/hono-api-reference": "^0.10.3",
    "@sinclair/typebox": "^0.34.48",
    "drizzle-orm": "^0.43.1",
    "hono": "^4.12.7",
    "simple-git": "^3.33.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@oxc-node/core": "^0.0.35",
    "@types/node": "^22.13.0",
    "drizzle-kit": "^0.30.0",
